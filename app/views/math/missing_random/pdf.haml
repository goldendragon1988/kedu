.container.mx-auto.p-4
  .divide-y.divide-gray-900.overflow-hidden.bg-white.border-2.border-gray-900.border-solid
    .px-4.py-5
      .flex.justify-between
        %div
          Name: _________________
        %h1.text-lg.leading-6.font-semibold.text-gray-900
          Missing Number
        %div
          Date: _________________
    .px-4.py-2
      .flex.justify-center.items-center
        %div Identify the missing value in each expression.
        .span.font-bold.text-xl.mx-2 5
        %div +
        .span.font-bold.text-xl.mx-2 blank
        %div =
        .span.font-bold.text-xl.mx-2 8
    .px-4.py-5
      %ul.grid.grid-cols-3
        - @data.each do |a, b, res, op|
          %li.border.border-gray-900.border-solid.py-3.text-number.flex.justify-around.grid.grid-cols-5
            .text-center= (a == "blank" ? "__" : a)
            .text-center= op
            .text-center= (b == "blank" ? "__" : b)
            .text-center =
            .text-center= (res == "blank" ? "__" : res)
