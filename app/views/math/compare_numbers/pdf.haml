.container.mx-auto.p-4
  .divide-y.divide-gray-900.overflow-hidden.bg-white.border-2.border-gray-900.border-solid
    .px-4.py-5
      .flex.justify-between
        %div
          Name: _________________
        %h1.text-lg.leading-6.font-semibold.text-gray-900
          Comparing Numbers
        %div
          Date: _________________
    .px-4.py-2
      .flex.justify-center.items-center
        %div Write the correct symbol. 
        .span.font-bold.text-xl.mx-2 < 
        %div is less than,  
        .span.font-bold.text-xl.mx-2 >
        %div is greater than, 
        .span.font-bold.text-xl.mx-2 =
        %div is equal to 
    .px-4.py-5
      %ul.grid.grid-cols-3
        - @data.each do |item|
          %li.border.border-gray-900.border-solid.px-2.py-3.text-number.flex.justify-around.grid.grid-cols-3
            .text-center= item.first
            .text-center ____
            .text-center= item.last
