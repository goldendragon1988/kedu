<div class="container mx-auto p-4">
  <div class="divide-y divide-gray-900 overflow-hidden bg-white border-2 border-gray-900 border-solid">
    <div class="px-4 py-5">
      <div class="flex justify-between">
        <div>Name: _________________</div>
        <h1 class="text-lg leading-6 font-semibold text-gray-900">Addition</h1>
        <div>Date: _________________</div>
      </div>
    </div>
    <div class="px-4 py-2">
      <div class="flex justify-center items-center">
        <div>Calculating the total of two or more numbers.</div>
        <span class="font-bold text-xl mx-2">1</span>
        <div>+</div>
        <span class="font-bold text-xl mx-2">1</span>
        <div>=</div>
        <span class="font-bold text-xl mx-2">2</span>
      </div>
    </div>
    <div class="px-4 py-5">
      <ul>
        <% @data.each do |item| %>
          <% compact_row = item.length > 2 %>
          <li class="border border-gray-900 border-solid py-3 <%= compact_row ? 'text-number-compact' : 'text-number' %>">
            <div class="flex justify-center items-center <%= compact_row ? 'gap-2' : 'gap-3' %> flex-wrap">
              <% item.each_with_index do |number, index| %>
                <div class="text-center"><%= number %></div>
                <% if index < item.length - 1 %>
                  <div class="text-center">+</div>
                <% end %>
              <% end %>
              <div class="text-center">=</div>
              <div class="text-center">__</div>
            </div>
          </li>
        <% end %>
      </ul>
    </div>
  </div>
</div>
